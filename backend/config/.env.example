# copy to backend/config/.env and fill in your values
# .env is gitignored, never commit real secrets

# express server port
PORT=3000

# postgres connection
# on macos homebrew, DB_USER is your system username, DB_PASSWORD is blank
# on windows, DB_USER=postgres with password set during install
DB_HOST=localhost
DB_USER=your_postgres_user
DB_PASSWORD=
DB_NAME=pokegrade

# psa public api token, register at psacard.com/publicapi
# each contributor uses their own token, do not share
PSA_ACCESS_TOKEN=your_psa_access_token
